---
import AuthorBox from './AuthorBox.astro';
import { CATEGORIES } from '../categories';
---
<aside class="layout__aside">
  <AuthorBox />

  <div class="widget">
    <h3 class="widget__title">Themen</h3>
    <ul class="cat-list">
      {CATEGORIES.map((c) => (
        <li><a href={`/kategorie/${c.slug}/`}><span>{c.title}</span><span aria-hidden="true">→</span></a></li>
      ))}
    </ul>
  </div>

  <div class="widget">
    <h3 class="widget__title">Newsletter</h3>
    <p style="font-size:0.92rem;">Hol dir Rezepte & Impulse für natürliche Schönheit direkt ins Postfach.</p>
    <a class="btn" href="/kontakt/">Jetzt anmelden</a>
  </div>
</aside>
