---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Impressum" description="Impressum">
  <section class="page-intro">
    <div class="container"><p class="eyebrow">Rechtliches</p><h1>Impressum</h1></div>
  </section>
  <div class="container" style="max-width:760px;padding-top:2.5rem;padding-bottom:4rem;">
    <div class="prose">
      <p><strong>Angaben gemäß § 5 DDG (Platzhalter – bitte ausfüllen):</strong></p>
      <p>
        [Dein Name]<br />
        [Straße & Hausnummer]<br />
        [PLZ Ort]
      </p>
      <h2>Kontakt</h2>
      <p>E-Mail: hallo@ganzheitlich-vital-gesund.de</p>
      <h2>Verantwortlich für den Inhalt</h2>
      <p>[Dein Name, Anschrift wie oben]</p>
      <p style="font-size:0.9rem;color:var(--muted);">
        Hinweis: Dies ist ein Platzhalter. Für ein rechtssicheres Impressum ggf.
        einen Impressums-Generator oder rechtlichen Rat nutzen.
      </p>
    </div>
  </div>
</BaseLayout>
